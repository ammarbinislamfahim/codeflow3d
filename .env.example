# Copy this file to .env and fill in your values
# cp .env.example .env

# Required for Docker Compose
DB_PASSWORD=change-this-to-a-secure-password
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars

# Backend config
ALLOWED_ORIGINS=http://localhost:5500

# Admin seed credentials (auto-created on startup if ADMIN_EMAIL is set)
# Password must meet strength rules: 8+ chars, uppercase, lowercase, number, special char
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234

# Frontend build (set on Netlify as well)
VITE_API_URL=http://localhost:8000
