# backend/.env.example

# Database
DB_PASSWORD=your-secure-postgres-password-here
DATABASE_URL=postgresql://codeflow:password@postgres:5432/codeflow_db

# Redis
REDIS_URL=redis://redis:6379/0

# Security
API_KEY=your-secret-api-key-min-32-chars
JWT_SECRET=your-secret-jwt-key-min-32-chars

# CORS
ALLOWED_ORIGINS=http://localhost:5500,https://yourdomain.com

# Environment
ENVIRONMENT=production
PARSER_TIMEOUT=5